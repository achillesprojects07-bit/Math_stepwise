{
  "version": "1.0.0",
  "studentFacingRules": {
    "showBackendRuleDetails": false,
    "allowedFeedback": [
      "Correct!",
      "Great work!",
      "Try one more like this.",
      "Practice again.",
      "Next lesson unlocked."
    ],
    "blockedFeedback": [
      "SCT failed",
      "mastery parameter failure",
      "accuracy condition not satisfied",
      "promotion requirement failed"
    ]
  },
  "mastery": {
    "requiresFinalCorrectedAccuracy": 1.0,
    "requiresCorrectionsCleared": true,
    "allowFinishAfterTimeExceeded": true,
    "timeIncludesCorrections": true,
    "sctBasedLevelsUseTimeAsGate": true,
    "nonSctLevelsUseTimeAsGate": false
  },
  "learningBlock": {
    "targetTimeFormula": "sctSecondsPerWorksheet * worksheetEquivalentCount",
    "allowOptionalExtraPractice": true,
    "optionalPracticeCanClearReview": true,
    "optionalPracticeIsNotRequired": true
  },
  "statuses": {
    "notStarted": "Not Started",
    "inProgress": "In Progress",
    "mastered": "Mastered",
    "completedNeedsFluency": "Completed — Needs Fluency",
    "needsReviewAccuracy": "Needs Review — Accuracy",
    "needsReviewRepeatedError": "Needs Review — Repeated Error",
    "levelReady": "Level Ready",
    "promoted": "Promoted"
  },
  "repeatRules": {
    "repeatIfUncorrectedMistakesRemain": true,
    "repeatIfTimeExceededOnSctLevel": true,
    "repeatIfRepeatedSkillErrors": true,
    "repeatIfAbandoned": true
  },
  "promotionRules": {
    "requiresAllRequiredLessonsCompleted": true,
    "requiresReviewQueueCleared": true,
    "requiresFinalLevelMasteryCheck": true,
    "requiresTimeGateForSctLevels": true,
    "requiresTimeGateForNonSctLevels": false
  },
  "unlockMode": "strict"
}
